# ===== 数据库 =====
# 留空则使用 SQLite（开发），设置则使用 PostgreSQL（生产）
DATABASE_URL=

# ===== JWT 认证 =====
# 必须设置为强随机字符串，切勿使用默认值！
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== CORS =====
# 允许的前端来源，多个用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== LLM / AI 语义检测 =====
# 留空则不启用 AI 检测
LLM_API_KEY=
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.1

# ===== 电商平台 API =====
# Amazon SP-API
AMAZON_SELLER_ID=
AMAZON_ACCESS_TOKEN=
AMAZON_REFRESH_TOKEN=
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=

# Shopee Open API
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=
SHOPEE_ACCESS_TOKEN=

# ===== 巡检告警 =====
# Webhook URL（飞书/钉钉/Slack）
PATROL_WEBHOOK_URL=
# 风险评分阈值，超过则触发告警
PATROL_ALERT_THRESHOLD=70
