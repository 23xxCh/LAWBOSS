{
  "name": "crossguard-desktop",
  "version": "0.3.0",
  "description": "出海法盾 CrossGuard - 跨境电商智能合规审查平台桌面客户端",
  "main": "./out/main/index.js",
  "author": "CrossGuard Team",
  "homepage": "https://github.com/23xxCh/LAWBOSS",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:win": "npm run build && electron-builder --win --config",
    "build:mac": "npm run build && electron-builder --mac --config",
    "build:linux": "npm run build && electron-builder --linux --config",
    "build:win-portable": "npm run build && electron-builder --win portable --config",
    "build:all": "npm run build && electron-builder --win --mac --linux --config"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.1",
    "antd": "^6.3.6",
    "axios": "^1.15.2",
    "electron-updater": "^6.3.9",
    "i18next": "^26.0.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "typescript": "~6.0.2",
    "vite": "^7.0.0"
  }
}
